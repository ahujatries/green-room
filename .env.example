# Vercel AI Gateway key — get one at https://vercel.com/dashboard (AI tab → API Keys)
# When deployed on Vercel, OIDC handles auth automatically and this can be omitted.
AI_GATEWAY_API_KEY=

# Optional: override the model routed through the Gateway.
# Any Gateway model slug works, e.g. anthropic/claude-opus-4.7, openai/gpt-5.5
CHAT_MODEL=anthropic/claude-sonnet-4.6

# Supabase — auth + reading the writer's own scripts/characters.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App base URL — used for OAuth redirects and the email "back to the room" link.
# Locally: http://localhost:3000. In prod: your deployed URL.
APP_BASE_URL=http://localhost:3000

# Private-preview password gate. When set, the WHOLE site sits behind this single
# shared password (see middleware.ts). Leave empty to disable the gate (e.g. local
# dev). Rotate by changing this value and redeploying.
SITE_PASSWORD=

# Canonical site URL for metadata/OG (no trailing slash). On Vercel this falls
# back to the deployment URL automatically, so it's optional.
NEXT_PUBLIC_SITE_URL=

# Sentry — error + performance monitoring.
# DSN is public-safe (NEXT_PUBLIC_). Org/project/token are only needed at BUILD
# time to upload source maps (readable stack traces); skip them to start.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Resend — transactional email ("email me this interview").
# tryarqo.com is already a verified sender domain in Resend.
RESEND_API_KEY=
# Optional override; defaults to "The Green Room <greenroom@tryarqo.com>".
GREEN_ROOM_FROM=
